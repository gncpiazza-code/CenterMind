# Renombrar a: .env.railway  (y no subir a git; ya está en .gitignore)
#
# Hay DOS cosas distintas (no mezclar):
#   1) Variables de la APP (Supabase, Shelfy) → lo que el contenedor RPA necesita al correr; también
#      podés subirlas al panel de Railway (Variables del servicio) con: python3 scripts/push_railway_env.py
#   2) Token del CLI (solo en tu Mac) → para que en la terminal funcione "railway whoami", "link", etc.
#      NO es SHELFY_API_KEY. Lo sacás de: railway.app → tu cuenta → Tokens (API) → token de CUENTA.
#      Poneló abajo como RAILWAY_API_TOKEN. El asistente en Cursor no "entra" a Railway solo: ejecuta
#      comandos en tu máquina cuando este archivo está en ShelfMind-RPA y exportás las variables.
#
#   set -a && source .env.railway && set +a
#   npx @railway/cli@latest whoami
#   npx @railway/cli@latest link

# --- (Opcional) Token de la API de Railway — solo para CLI en tu Mac, no hace falta en el deploy del RPA ---
# RAILWAY_API_TOKEN=

# --- Supabase (RPC Vault) — alcanza con URL + UNA de las claves de abajo ---
# Panel: supabase.com → Project → Settings (engranaje) → API
SUPABASE_URL=
# Misma clave "service" que en el backend (suele llamarse en Railway SUPABASE_KEY o service_role)
SUPABASE_KEY=
# o: SUPABASE_SERVICE_KEY=  (el RPA acepta cualquiera de las dos vía lib/vault_client)

# --- API pública de Shelfy ---
# Si no tenés URL en Railway: el código usa https://api.shelfycenter.com por defecto.
# Solo hace falta definir URL si el backend no es el público (ej. otro API_URL o BACKEND_URL en el servicio)
# SHELFY_API_URL=
SHELFY_API_KEY=

# Opcionales
# RPA_HEADLESS=true
# RPA_START_MODE=scheduler
