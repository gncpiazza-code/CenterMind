              )}
            </div>
          )}

          {/* ── Contextual: Cobranza ──────────────────────────────────────── */}
          {tipo === "cobranza" && (
            <div className="space-y-2 rounded-xl bg-[var(--shelfy-bg)] border border-[var(--shelfy-border)] p-3">
