sql = """
CREATE OR REPLACE FUNCTION fn_admin_global_monitoring()
RETURNS TABLE (
    id_dist BIGINT,
    nombre_dist TEXT,
    total_exhibiciones BIGINT,
    total_ventas_erp BIGINT,
    total_clientes_erp BIGINT,
    ultima_actividad TIMESTAMP WITH TIME ZONE,
