                </Card>
            )}
        </div>
    );
}

function KPICard({ title, value, icon, trend }: { title: string, value: string | number, icon: React.ReactNode, trend?: string }) {
    return (
        <Card className="flex flex-col gap-2 relative overflow-hidden">
