};

const PERMISSION_KEYS: { key: string; label: string; group: string }[] = [
  { key: "menu_dashboard",    label: "Dashboard",            group: "Menú" },
  { key: "menu_supervision",  label: "Supervisión",          group: "Menú" },
  { key: "menu_objetivos",    label: "Objetivos",            group: "Menú" },
