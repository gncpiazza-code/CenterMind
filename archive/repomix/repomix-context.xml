        await createObjetivo({
          id_distribuidor: selectedDist,
          id_vendedor: pin.id_vendedor,
          tipo: objTipo,
          id_target_pdv: pdvId,
          nombre_pdv: pin.nombre,
          nombre_vendedor: pin.vendedor,
          descripcion: autoDesc || undefined,
