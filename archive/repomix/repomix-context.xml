            }}>
              <div style={{ fontWeight: 700, color: "#111", marginBottom: 6, fontSize: 12 }}>Almacén Don Pedro</div>
              {[["Razón social", "Don Pedro S.R.L."], ["N° Cliente ERP", "1042"], ["Dirección", "Av. San Martín 456"], ["Canal", "Almacén"]].map(([k, v]) => (
