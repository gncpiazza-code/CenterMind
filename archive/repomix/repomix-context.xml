            {rutasLocal.length} rutas
          </p>
        )}
      </div>

      {/* Lista scrollable */}
      <div style={{ flex: 1, overflowY: "auto", minHeight: 0 }}>
        {selected ? (
          rutasLocal.length > 0 ? (
