          const vendorName = firstPin?.vendedor ?? "";
          const norm = (s: string) => s.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "").trim();
          const vend = data.vendedores.find((v) => norm(v.vendedor) === norm(vendorName));
