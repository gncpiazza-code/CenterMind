        }, on_conflict="tenant_id, fecha").execute()

        rows_cc = datos.get("detalle_cuentas", [])
        saved = 0
        if rows_cc:
            saved = _enrich_and_store_cc(id_distribuidor, fecha_str, rows_cc)
