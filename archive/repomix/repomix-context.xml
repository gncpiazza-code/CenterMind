    # ─────────────────────────────────────────────────────────────────────
    # SETUP
    # ─────────────────────────────────────────────────────────────────────

    def _setup_window(self) -> None:
        self.root.title("Shelfy · Panel Maestro")
        self.root.geometry("1340x860")
        self.root.minsize(1000, 640)
        self.root.configure(bg=BG)
