                                    <XAxis type="number" hide />
                                    <YAxis dataKey="articulo" type="category" width={100} tick={{ fontSize: 10 }} />
                                    <Tooltip />
                                    <Bar dataKey="cantidad" fill="#7c3aed" radius={[0, 4, 4, 0]} />
