  // ── Accordion handlers with query prefetching ─────────────────────────────
  async function handleVend(id: number) {
    if (openVend === id) { 
      setOpenVend(null); 
      return; 
    }
    setOpenVend(id); 
    setOpenRuta(null); 
    setOpenCliente(null);
    
