              </div>
            )}
          </div>
          <div style={{ display: "flex", gap: 8 }}>
            <button
              onClick={toggleFullscreen}
              style={{
                background: isFullscreen ? "rgba(124,58,237,0.2)" : "rgba(255,255,255,0.05)",
                border: "1px solid rgba(124,58,237,0.4)",
