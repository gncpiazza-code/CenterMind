              }}
            >
              <Monitor size={12} />
              {isFullscreen ? "Salir Fullscreen" : "Pantalla Completa"}
            </button>
            <button
              onClick={() => loadData(false)}
              style={{
                background: "rgba(255,255,255,0.05)",
                border: "1px solid rgba(255,255,255,0.1)",
                borderRadius: 8,
                padding: "6px 12px",
