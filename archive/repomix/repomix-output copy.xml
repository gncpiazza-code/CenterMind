                {!selectedSucursal
                  ? "Seleccioná una sucursal para comenzar"
                  : "Activá un vendedor, ruta o PDV para verlos en el mapa"
                }
              </p>
            </div>
          ) : (
            <MapaRutas pines={pines} fullscreenPanel={vendorPanelContent} />
          )}

        </div>

        {/* ── RIGHT PANEL — lista vendedores/rutas ────────────────────────── */}
