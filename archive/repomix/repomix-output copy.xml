                          className="rounded-lg border border-[var(--shelfy-border)] bg-[var(--shelfy-bg)] text-[var(--shelfy-text)] px-3 py-2 text-sm focus:outline-none focus:border-[var(--shelfy-primary)] w-36"
                        />
                      </div>

                      {/* Estado */}
                      <DropdownMultiSelect
                        label="Estado"
                        options={ESTADOS}
                        selected={selectedEstados}
