<script>
// ===== CONSTANTS =====
const TOTAL_DURATION = 45000; // 45 seconds

// ===== PROGRESS BAR =====
const progressBar = document.getElementById('progress-bar');
let startTime = null;
let animFrame = null;

function updateProgress(ts) {
  if (!startTime) startTime = ts;
  const elapsed = ts - startTime;
  const pct = Math.min(100, (elapsed / TOTAL_DURATION) * 100);
  progressBar.style.width = pct + '%';
  if (pct < 100) animFrame = requestAnimationFrame(updateProgress);
}

// ===== CURSOR =====
const cursor = document.getElementById('cursor');
let cursorX = -100, cursorY = -100;

function moveCursor(x, y, duration) {
  return new Promise(resolve => {
    cursor.style.transition = `transform ${duration}ms cubic-bezier(0.25, 0.1, 0.25, 1)`;
    cursor.style.transform = `translate(${x}px, ${y}px)`;
    cursorX = x; cursorY = y;
    setTimeout(resolve, duration);
  });
}

function clickCursor(x, y, color = '') {
  return new Promise(resolve => {
    const r = document.createElement('div');
    r.className = 'ripple' + (color ? ' ' + color : '');
    r.style.cssText = `width:40px;height:40px;left:${x - 20}px;top:${y - 20}px;`;
    document.body.appendChild(r);
    // Click scale on cursor
    cursor.style.transform = `translate(${x}px, ${y}px) scale(0.85)`;
    setTimeout(() => {
      cursor.style.transform = `translate(${x}px, ${y}px) scale(1)`;
    }, 120);
    setTimeout(() => { r.remove(); resolve(); }, 700);
  });
}

async function moveAndClick(x, y, moveDuration = 700, color = '') {
  await moveCursor(x, y, moveDuration);
  await delay(80);
  await clickCursor(x, y, color);
}

function delay(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

// ===== SCENES =====
const scenes = ['scene-intro','scene-kpis','scene-exhibits','scene-map','scene-cuentas','scene-scanner','scene-outro'];
let currentScene = -1;

function showScene(id) {
  return new Promise(resolve => {
    // Hide current
    if (currentScene >= 0) {
      const prev = document.getElementById(scenes[currentScene]);
      if (prev) prev.classList.remove('active');
    }
    currentScene = scenes.indexOf(id);
    const el = document.getElementById(id);
    if (el) {
      el.classList.add('active');
    }
    setTimeout(resolve, 450);
  });
}

// ===== COUNTER ANIMATION =====
function animateCounter(el, start, end, duration, formatter) {
  const startTime = performance.now();
  function update(ts) {
    const elapsed = ts - startTime;
    const progress = Math.min(elapsed / duration, 1);
    const eased = 1 - Math.pow(1 - progress, 3);
    const value = Math.round(start + (end - start) * eased);
    el.textContent = formatter(value);
    if (progress < 1) requestAnimationFrame(update);
  }
  requestAnimationFrame(update);
}

// ===== PARTICLES =====
function createParticles() {
  const container = document.getElementById('particles');
  for (let i = 0; i < 20; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    const size = Math.random() * 4 + 1;
    p.style.cssText = `
      width:${size}px;height:${size}px;
      left:${Math.random() * 100}%;
      animation-duration:${Math.random() * 8 + 6}s;
      animation-delay:${Math.random() * 5}s;
    `;
    container.appendChild(p);
  }
}

// ===== MAP DOTS =====
const mapDots = [
  // Juan: cyan
  {x:22, y:28, color:'#06b6d4', seller:1, label:'Super El Sol'},
  {x:18, y:50, color:'#06b6d4', seller:1, label:'Kiosco Norte'},
  {x:30, y:38, color:'#06b6d4', seller:1, label:'Farmacia Central'},
  {x:25, y:62, color:'#06b6d4', seller:1, label:'Almacén Los Pinos'},
  {x:12, y:42, color:'#06b6d4', seller:1, label:'PDV #0081'},
  // María: green
  {x:55, y:25, color:'#22c55e', seller:2, label:'Super Norte'},
  {x:62, y:44, color:'#22c55e', seller:2, label:'Kiosco Central'},
  {x:48, y:55, color:'#22c55e', seller:2, label:'Almacén Pérez'},
  {x:70, y:32, color:'#22c55e', seller:2, label:'PDV #0142'},
  // Carlos: amber
  {x:75, y:58, color:'#f59e0b', seller:3, label:'Supermercado Sur'},
  {x:82, y:70, color:'#f59e0b', seller:3, label:'Kiosco Sur'},
  {x:68, y:72, color:'#f59e0b', seller:3, label:'Almacén Don Pedro'},
  {x:85, y:45, color:'#f59e0b', seller:3, label:'Distribuidora'},
  {x:78, y:38, color:'#f59e0b', seller:3, label:'PDV #0217'},
  // Ana: pink
  {x:38, y:76, color:'#ec4899', seller:4, label:'Super El Ángel'},
  {x:44, y:85, color:'#ec4899', seller:4, label:'Kiosco Palermo'},
  {x:52, y:78, color:'#ec4899', seller:4, label:'Almacén Belgrano'},
  {x:32, y:88, color:'#ec4899', seller:4, label:'Mini Market'},
];

function renderMapDots() {
  const map = document.getElementById('map-container');
  mapDots.forEach((d, i) => {
    const dot = document.createElement('div');
    dot.className = 'map-dot';
    dot.id = `mdot-${i}`;
    dot.style.cssText = `
      left:${d.x}%;top:${d.y}%;
      width:12px;height:12px;
      background:${d.color};
      box-shadow:0 0 10px ${d.color}80;
      color:${d.color};
    `;
    const label = document.createElement('div');
    label.className = 'map-label';
    label.textContent = d.label;
    dot.appendChild(label);
    map.appendChild(dot);
  });
}

function showSellerDots(sellerIdx, withDelay = true) {
  mapDots.forEach((d, i) => {
    if (d.seller === sellerIdx) {
      setTimeout(() => {
        const dot = document.getElementById(`mdot-${i}`);
        if (dot) dot.classList.add('visible');
      }, withDelay ? i * 80 : 0);
    }
  });
}

function toggleSeller(n) {
  const routes = document.getElementById(`routes-${n}`);
  if (routes) routes.classList.toggle('open');
}

function toggleEye(n) {
  const eye = document.getElementById(`eye-${n}`);
  if (eye) eye.classList.toggle('on');
}

function toggleRoute(n) {
  const pdvs = document.getElementById(`pdvs-${n}`);
  const exp = document.getElementById(`rexp-${n}`);
  if (pdvs) pdvs.classList.toggle('open');
  if (exp) exp.classList.toggle('open');
}

// ===== MAIN DEMO SEQUENCE =====
let demoTimeouts = [];

function clearTimeouts() {
  demoTimeouts.forEach(t => clearTimeout(t));
  demoTimeouts = [];
  if (animFrame) cancelAnimationFrame(animFrame);
}

function t(fn, ms) {
  demoTimeouts.push(setTimeout(fn, ms));
}

async function runDemo() {
  startTime = null;
  animFrame = requestAnimationFrame(updateProgress);
  createParticles();
  renderMapDots();

  // ===== SCENE 1: INTRO (0–3s) =====
  await showScene('scene-intro');
  cursor.style.transform = 'translate(-100px, -100px)';

  // ===== SCENE 2: KPIs (3–10s) =====
  t(async () => {
    await showScene('scene-kpis');
    // Animate bars after scene loads
    const barHeights = [72, 85, 95, 88, 100, 65, 110];
    const bars = document.querySelectorAll('.mini-bar');
    bars.forEach((b, i) => {
      setTimeout(() => { b.style.height = barHeights[i] + 'px'; }, i * 100 + 300);
    });
    // Counter animations
    animateCounter(document.getElementById('kpi-pdvs'), 0, 2847, 1800, v => v.toLocaleString('es-AR'));
    setTimeout(() => animateCounter(document.getElementById('kpi-eff'), 0, 89, 1600, v => v + '%'), 200);
    setTimeout(() => animateCounter(document.getElementById('kpi-rev'), 0, 1200000, 2000, v => '$' + (v/1000000).toFixed(1) + 'M'), 400);
    setTimeout(() => animateCounter(document.getElementById('kpi-pend'), 0, 47, 1400, v => v), 600);

    // Cursor hover KPIs
    await delay(1200);
    await moveCursor(200, 300, 600);
    await delay(300);
    await moveCursor(430, 300, 500);
    await delay(300);
    await moveCursor(660, 300, 500);
    await delay(300);
    await moveCursor(900, 300, 500);
  }, 3000);

  // ===== SCENE 3: EXHIBITS (10–18s) =====
  t(async () => {
    await showScene('scene-exhibits');
    await delay(600);
    // Move cursor to first exhibit card
    await moveCursor(220, 360, 700);
    await delay(300);
    await moveAndClick(220, 360, 400);
    // Open modal
    await delay(200);
    const modal = document.getElementById('exhibit-modal');
    modal.classList.add('open');
    await delay(600);
    // Move to Approve button
    await moveCursor(490, 540, 700);
    await delay(300);
    await moveAndClick(490, 540, 300, 'green');
    // Change badge to approved
    await delay(200);
    const modalBadge = document.getElementById('modal-badge');
    modalBadge.className = 'badge approved';
    modalBadge.textContent = '✓ APROBADA';
    const badge1 = document.getElementById('badge-1');
    badge1.className = 'badge approved';
    badge1.textContent = '✓ APROBADA';
    await delay(1200);
    // Close modal
    modal.classList.remove('open');
    await delay(500);
    // Hover second card
    await moveCursor(640, 360, 600);
    await delay(500);
    await moveCursor(1060, 360, 500);
  }, 10000);

  // ===== SCENE 4: MAP (18–28s) =====
  t(async () => {
    await showScene('scene-map');
    await delay(600);
    // Click eye of Juan García (approx position)
    await moveCursor(1230, 178, 700);
    await delay(300);
    await moveAndClick(1230, 178, 300, 'cyan');
    document.getElementById('eye-1').classList.add('on');
    showSellerDots(1, true);
    await delay(800);
    // Click eye of María López
    await moveCursor(1230, 228, 600);
    await delay(200);
    await moveAndClick(1230, 228, 300, 'green');
    document.getElementById('eye-2').classList.add('on');
    showSellerDots(2, true);
    await delay(1000);
    // Expand Juan García routes
    await moveCursor(1085, 178, 700);
    await delay(300);
    await moveAndClick(1085, 178, 300);
    document.getElementById('routes-1').classList.add('open');
    await delay(800);
    // Expand route 1 PDVs
    await moveCursor(1148, 218, 600);
    await delay(200);
    await moveAndClick(1148, 218, 300);
    document.getElementById('pdvs-1').classList.add('open');
    document.getElementById('rexp-1').classList.add('open');
    await delay(1200);
    // Show Carlos and Ana dots
    showSellerDots(3, true);
    showSellerDots(4, true);
  }, 18000);

  // ===== SCENE 5: CUENTAS CORRIENTES (28–35s) =====
  t(async () => {
    await showScene('scene-cuentas');
    await delay(800);
    // Move over table rows
    await moveCursor(640, 390, 700);
    await delay(400);
    await moveCursor(640, 440, 400);
    await delay(300);
    await moveCursor(640, 490, 400);
    await delay(500);
    // Click CSV button
    await moveCursor(1080, 200, 700);
    await delay(300);
    await moveAndClick(1080, 200, 400, 'green');
    document.getElementById('csv-badge').classList.add('show');
    await delay(1200);
    document.getElementById('csv-badge').classList.remove('show');
  }, 28000);

  // ===== SCENE 6: SCANNER (35–43s) =====
  t(async () => {
    await showScene('scene-scanner');
    await delay(600);
    // Move to scanner button
    await moveCursor(640, 360, 700);
    await delay(400);
    await moveAndClick(640, 360, 400);
    // Trigger scanner
    document.getElementById('scanner-trigger').style.opacity = '0';
    document.getElementById('scanner-trigger').style.transition = 'opacity 0.3s';
    setTimeout(() => {
      document.getElementById('scanner-trigger').style.display = 'none';
    }, 300);
    document.getElementById('scanner-modal').classList.add('open');
    cursor.style.transform = 'translate(-100px, -100px)';
    await delay(2200);
    // Results appear staggered
    document.getElementById('sresult-1').classList.add('appear');
    await delay(300);
    document.getElementById('sresult-2').classList.add('appear');
    await delay(300);
    document.getElementById('sresult-3').classList.add('appear');
    await delay(600);
    document.getElementById('scanner-status').textContent = '3 PDVs encontrados';
    document.getElementById('scanner-status').style.animation = 'none';
    document.getElementById('scanner-status').style.color = 'var(--amber)';
  }, 35000);

  // ===== SCENE 7: OUTRO (43–45s) =====
  t(async () => {
    await showScene('scene-outro');
    cursor.style.transform = 'translate(-100px, -100px)';
  }, 43000);
}

function restartDemo() {
  clearTimeouts();
  // Reset all scene states
  scenes.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('active');
  });
  currentScene = -1;
  progressBar.style.width = '0%';
  // Reset map dots
  mapDots.forEach((d, i) => {
    const dot = document.getElementById(`mdot-${i}`);
    if (dot) dot.classList.remove('visible');
  });
  // Reset eyes
  [1,2,3,4].forEach(n => {
    const e = document.getElementById(`eye-${n}`);
    if (e) e.classList.remove('on');
    const r = document.getElementById(`routes-${n}`);
    if (r) r.classList.remove('open');
  });
  // Reset PDVs
  const p1 = document.getElementById('pdvs-1');
  if (p1) p1.classList.remove('open');
  const re1 = document.getElementById('rexp-1');
  if (re1) re1.classList.remove('open');
  // Reset modal
  const modal = document.getElementById('exhibit-modal');
  if (modal) modal.classList.remove('open');
  const mb = document.getElementById('modal-badge');
  if (mb) { mb.className = 'badge pending'; mb.textContent = '● PENDIENTE'; }
  const b1 = document.getElementById('badge-1');
  if (b1) { b1.className = 'badge pending'; b1.textContent = '● PENDIENTE'; }
  // Reset CSV
  const csvb = document.getElementById('csv-badge');
  if (csvb) csvb.classList.remove('show');
  // Reset scanner
  const st = document.getElementById('scanner-trigger');
  if (st) { st.style.display = ''; st.style.opacity = '1'; }
  const sm = document.getElementById('scanner-modal');
  if (sm) sm.classList.remove('open');
  ['sresult-1','sresult-2','sresult-3'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.classList.remove('appear');
  });
  const ss = document.getElementById('scanner-status');
  if (ss) {
    ss.textContent = 'Escaneando zona...';
    ss.style.animation = '';
    ss.style.color = '';
  }
  // Reset bars
  document.querySelectorAll('.mini-bar').forEach(b => b.style.height = '0');
  // Reset counters
  ['kpi-pdvs','kpi-eff','kpi-rev','kpi-pend'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.textContent = '0';
  });
  // Restart particles
  const particles = document.getElementById('particles');
  if (particles) particles.innerHTML = '';
  // Remove old map dots and re-render
  mapDots.forEach((d, i) => {
    const dot = document.getElementById(`mdot-${i}`);
    if (dot) dot.remove();
  });

  setTimeout(() => runDemo(), 100);
}

// ===== START =====
window.addEventListener('load', () => {
  setTimeout(runDemo, 200);
});
</script>
</body>
</html>
</file>

