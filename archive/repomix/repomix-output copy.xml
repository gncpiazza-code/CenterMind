    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    background: rgba(34,197,94,0.15);
    color: var(--green);
    border: 1px solid rgba(34,197,94,0.25);
    opacity: 0;
    transition: opacity 0.3s;
    margin-left: 10px;
  }
  .csv-badge.show { opacity: 1; }

  /* ===== SCENE 6: SCANNER ===== */
  #scene-scanner {
    background: #0a0f1a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }
  .scanner-trigger-area {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 24px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
    transition: all 0.3s;
    cursor: pointer;
    width: 320px;
  }
  .scanner-btn-icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: rgba(245,158,11,0.15);
    border: 2px solid var(--amber);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    animation: radar-pulse 2s ease infinite;
    flex-shrink: 0;
  }
  @keyframes radar-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(245,158,11,0.4); }
    50% { box-shadow: 0 0 0 12px rgba(245,158,11,0); }
  }
  .scanner-btn-text { font-size: 16px; font-weight: 700; }
  .scanner-btn-sub { font-size: 12px; color: var(--text3); margin-top: 2px; }

  .scanner-modal {
    position: absolute;
    inset: 0;
    background: #0a0f1a;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.4s;
    pointer-events: none;
    z-index: 10;
  }
  .scanner-modal.open {
    opacity: 1;
    pointer-events: auto;
  }
  .radar-container {
    position: relative;
    width: 240px;
    height: 240px;
    margin-bottom: 32px;
  }
  .radar-ring {
    position: absolute;
    border-radius: 50%;
    border: 1.5px solid var(--green);
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0);
    opacity: 0;
    animation: radar-ring 2.4s ease-out infinite;
  }
  .radar-ring:nth-child(1) { width: 60px; height: 60px; animation-delay: 0s; }
  .radar-ring:nth-child(2) { width: 110px; height: 110px; animation-delay: 0.4s; }
  .radar-ring:nth-child(3) { width: 165px; height: 165px; animation-delay: 0.8s; }
  .radar-ring:nth-child(4) { width: 220px; height: 220px; animation-delay: 1.2s; }
  @keyframes radar-ring {
    0% { transform: translate(-50%, -50%) scale(0.2); opacity: 0.8; }
    100% { transform: translate(-50%, -50%) scale(1); opacity: 0; }
  }
  .radar-center {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--green);
    box-shadow: 0 0 20px var(--green);
  }
  .scanner-status {
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 3px;
    color: var(--green);
    text-transform: uppercase;
    margin-bottom: 28px;
    animation: blink-text 1s ease infinite;
  }
  @keyframes blink-text {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
  .scanner-results {
    display: flex;
    flex-direction: column;
    gap: 10px;
    width: 420px;
  }
  .scanner-result {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(34,197,94,0.2);
    border-radius: 10px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.4s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .scanner-result.appear {
    opacity: 1;
    transform: translateX(0);
  }
  .dist-badge {
    background: rgba(34,197,94,0.15);
    color: var(--green);
    border: 1px solid rgba(34,197,94,0.3);
    border-radius: 6px;
    padding: 3px 10px;
    font-size: 12px;
    font-weight: 700;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .result-name { font-size: 13px; font-weight: 600; flex: 1; }
  .result-sub { font-size: 11px; color: var(--text3); margin-top: 2px; }

  /* ===== SCENE 7: OUTRO ===== */
  #scene-outro {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--bg);
  }
  .outro-logo {
    font-size: 64px;
    font-weight: 900;
    letter-spacing: -3px;
    background: linear-gradient(135deg, #f59e0b, #fbbf24);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 12px;
  }
  .outro-url {
    font-size: 18px;
    color: var(--text3);
    letter-spacing: 2px;
  }
  .outro-line {
    width: 60px;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--amber), transparent);
    margin: 20px 0;
  }
  .outro-tagline {
    font-size: 13px;
    color: var(--text3);
    letter-spacing: 1px;
    text-transform: uppercase;
  }
</style>
</head>
