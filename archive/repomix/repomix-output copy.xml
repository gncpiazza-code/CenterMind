// ── Small eye toggle button ───────────────────────────────────────────────────
function EyeBtn({
  on, loading, color, onClick, title,
}: {
  on: boolean; loading?: boolean; color?: string;
  onClick: () => void; title?: string;
}) {
  return (
    <button
      onClick={e => { e.stopPropagation(); onClick(); }}
