<script>
  const TOTAL_DURATION = 45000; // 45 segundos

  // Escenas: [inicio_ms, fin_ms]
  const SCENES = [
    { id: 'scene1',  start:  0,    end:  4000 },
    { id: 'scene2',  start:  4000, end: 10000 },
    { id: 'scene3',  start: 10000, end: 17000 },
    { id: 'scene4',  start: 17000, end: 24000 },
    { id: 'scene5',  start: 24000, end: 30000 },
    { id: 'scene6',  start: 30000, end: 37000 },
    { id: 'scene7',  start: 37000, end: 44000 },
    { id: 'scene8',  start: 44000, end: 45000 },
  ];

  let startTime = null;
  let rafId = null;
  let currentSceneId = null;
  let pdvAnimDone = false;
  let nearbyAnimDone = false;
  let countersAnimDone = false;
  let counterRafId = null;

  function resetAnimStates() {
    pdvAnimDone = false;
    nearbyAnimDone = false;
    countersAnimDone = false;
    if (counterRafId) { cancelAnimationFrame(counterRafId); counterRafId = null; }
    document.querySelectorAll('.pdv-card').forEach(el => el.classList.remove('visible'));
    document.querySelectorAll('.nearby-item').forEach(el => el.classList.remove('visible'));
    ['counter1','counter2','counter3','counter4'].forEach(id => {
      const el = document.getElementById(id);
      if (el) el.textContent = id === 'counter2' ? '$0' : '0';
    });
  }

  // ── Mapa: puntos ──
  const MAP_DOTS = [
    {x:12,y:18,c:'#22c55e',s:10},{x:25,y:42,c:'#f59e0b',s:8},{x:40,y:15,c:'#6366f1',s:11},
    {x:55,y:55,c:'#22c55e',s:9},{x:70,y:28,c:'#ef4444',s:10},{x:82,y:65,c:'#f59e0b',s:8},
    {x:18,y:70,c:'#6366f1',s:10},{x:35,y:82,c:'#22c55e',s:9},{x:48,y:38,c:'#f97316',s:12},
    {x:63,y:78,c:'#ef4444',s:8},{x:78,y:48,c:'#22c55e',s:10},{x:90,y:20,c:'#6366f1',s:9},
    {x:8,y:50,c:'#f59e0b',s:11},{x:42,y:62,c:'#ef4444',s:8},{x:88,y:82,c:'#22c55e',s:10},
    {x:60,y:12,c:'#f97316',s:9},{x:30,y:22,c:'#22c55e',s:8},{x:72,y:55,c:'#6366f1',s:11},
  ];

  function buildMap() {
    const container = document.getElementById('mapContainer');
    if (!container) return;
    MAP_DOTS.forEach(d => {
      const dot = document.createElement('div');
      dot.className = 'map-dot';
      dot.style.cssText = `
        left: ${d.x}%;
        top: ${d.y}%;
        width: ${d.s}px;
        height: ${d.s}px;
        background: ${d.c};
        box-shadow: 0 0 ${d.s * 1.5}px ${d.c}88;
        opacity: 0.85;
      `;
      container.appendChild(dot);
    });
  }
  buildMap();

  // ── PDV cascade animation ──
  function animatePDVs() {
    if (pdvAnimDone) return;
    pdvAnimDone = true;
    const cards = document.querySelectorAll('.pdv-card');
    cards.forEach((card, i) => {
      setTimeout(() => card.classList.add('visible'), i * 280 + 100);
    });
  }

  // ── Nearby items animation ──
  function animateNearby() {
    if (nearbyAnimDone) return;
    nearbyAnimDone = true;
    const items = document.querySelectorAll('.nearby-item');
    items.forEach((item, i) => {
      setTimeout(() => item.classList.add('visible'), i * 350 + 600);
    });
  }

  // ── Counter animation ──
  function animateCounters(sceneStart, now) {
    if (countersAnimDone) return;
    countersAnimDone = true;
    const duration = 2400;
    const targets = [
      { id: 'counter1', target: 2847, format: v => Math.round(v).toLocaleString('es-AR') },
      { id: 'counter2', target: 2.4, format: v => '$' + v.toFixed(1) + 'M' },
      { id: 'counter3', target: 47, format: v => Math.round(v) },
      { id: 'counter4', target: 18, format: v => Math.round(v) + ' días' },
    ];
    const startT = performance.now();
    function step(ts) {
      const elapsed = ts - startT;
      const progress = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      targets.forEach(t => {
        const el = document.getElementById(t.id);
        if (el) el.textContent = t.format(t.target * ease);
      });
      if (progress < 1) { counterRafId = requestAnimationFrame(step); }
    }
    counterRafId = requestAnimationFrame(step);
  }

  // ── Main loop ──
  function tick(ts) {
    if (!startTime) startTime = ts;
    const elapsed = ts - startTime;
    const progress = Math.min(elapsed / TOTAL_DURATION, 1);

    // Progress bar
    document.getElementById('progress-bar').style.width = (progress * 100) + '%';

    // Which scene is active?
    let activeScene = null;
    for (const s of SCENES) {
      if (elapsed >= s.start && elapsed < s.end) { activeScene = s; break; }
    }
    // Handle last frame
    if (elapsed >= TOTAL_DURATION) {
      activeScene = SCENES[SCENES.length - 1];
    }

    if (activeScene && activeScene.id !== currentSceneId) {
      // Deactivate all
      document.querySelectorAll('.scene').forEach(el => el.classList.remove('active'));
      // Activate new
      document.getElementById(activeScene.id).classList.add('active');
      currentSceneId = activeScene.id;
    }

    // Scene-specific triggers
    if (currentSceneId === 'scene3') {
      const sceneElapsed = elapsed - 10000;
      if (sceneElapsed > 800) animatePDVs();
    }
    if (currentSceneId === 'scene6') {
      const sceneElapsed = elapsed - 30000;
      if (sceneElapsed > 500) animateNearby();
    }
    if (currentSceneId === 'scene7') {
      animateCounters();
    }

    if (progress < 1) {
      rafId = requestAnimationFrame(tick);
    } else {
      // End: keep last scene visible
      document.querySelectorAll('.scene').forEach(el => el.classList.remove('active'));
      document.getElementById('scene8').classList.add('active');
      document.getElementById('progress-bar').style.width = '100%';
    }
  }

  function startDemo() {
    startTime = null;
    currentSceneId = null;
    if (rafId) cancelAnimationFrame(rafId);
    resetAnimStates();
    document.querySelectorAll('.scene').forEach(el => el.classList.remove('active'));
    document.getElementById('progress-bar').style.width = '0%';
    rafId = requestAnimationFrame(tick);
  }

  function restartDemo() { startDemo(); }

  // Auto-start
  startDemo();
</script>
</body>
</html>
