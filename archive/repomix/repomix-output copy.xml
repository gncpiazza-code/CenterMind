<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shelfy — Panel de Supervisión Demo</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0f1117;
      --panel: #1a1d27;
      --panel2: #21263a;
      --amber: #f59e0b;
      --amber-light: #fbbf24;
      --amber-dark: #d97706;
      --green: #22c55e;
      --red: #ef4444;
      --orange: #f97316;
      --text: #ffffff;
      --text-secondary: rgba(255,255,255,0.6);
      --text-muted: rgba(255,255,255,0.35);
      --border: rgba(255,255,255,0.08);
      --glow: rgba(245,158,11,0.15);
    }

    html, body {
      width: 1280px;
      height: 720px;
      overflow: hidden;
      font-family: 'Inter', sans-serif;
      background: var(--bg);
      color: var(--text);
    }

    #app {
      width: 1280px;
      height: 720px;
      position: relative;
      overflow: hidden;
    }

    /* ── Progress bar ── */
    #progress-bar-wrap {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 3px;
      background: rgba(255,255,255,0.06);
      z-index: 9999;
    }
    #progress-bar {
      height: 100%;
      background: linear-gradient(90deg, var(--amber-dark), var(--amber), var(--amber-light));
      width: 0%;
      transition: width 0.1s linear;
      box-shadow: 0 0 8px var(--amber);
    }

    /* ── Restart button ── */
    #restart-btn {
      position: fixed;
      top: 18px;
      right: 18px;
      z-index: 9999;
      background: rgba(245,158,11,0.12);
      border: 1px solid rgba(245,158,11,0.3);
      color: var(--amber);
      font-family: 'Inter', sans-serif;
      font-size: 13px;
      font-weight: 600;
      padding: 8px 16px;
      border-radius: 8px;
      cursor: pointer;
      backdrop-filter: blur(8px);
      transition: background 0.2s, transform 0.1s;
      letter-spacing: 0.02em;
    }
    #restart-btn:hover { background: rgba(245,158,11,0.22); transform: scale(1.03); }
    #restart-btn:active { transform: scale(0.97); }

    /* ── Scene base ── */
    .scene {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.7s ease;
    }
    .scene.active {
      opacity: 1;
      pointer-events: all;
    }

    /* ─────────────────────────────────────
       SCENE 1 — Título
    ───────────────────────────────────── */
    #scene1 {
      background: radial-gradient(ellipse at 50% 40%, #1c1a0a 0%, var(--bg) 70%);
      flex-direction: column;
      gap: 16px;
      text-align: center;
    }
    #scene1::before {
      content: '';
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 20% 80%, rgba(245,158,11,0.07) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(245,158,11,0.05) 0%, transparent 50%);
      animation: bgPulse 4s ease-in-out infinite alternate;
    }
    @keyframes bgPulse {
      from { opacity: 0.6; }
      to { opacity: 1; }
    }
    .s1-logo {
      font-size: 88px;
      font-weight: 900;
      letter-spacing: -4px;
      background: linear-gradient(135deg, var(--amber) 0%, var(--amber-light) 50%, var(--amber-dark) 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      filter: drop-shadow(0 0 30px rgba(245,158,11,0.4));
      position: relative;
      z-index: 1;
      animation: logoFloat 3s ease-in-out infinite alternate;
    }
    @keyframes logoFloat {
      from { transform: translateY(0px); }
      to { transform: translateY(-6px); }
    }
    .s1-subtitle {
      font-size: 26px;
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.5px;
      position: relative;
      z-index: 1;
    }
    .s1-tagline {
      font-size: 15px;
      color: var(--text-secondary);
      font-weight: 400;
      letter-spacing: 0.04em;
      position: relative;
      z-index: 1;
      margin-top: 4px;
    }
    .s1-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.25);
      border-radius: 100px;
      padding: 6px 16px;
      font-size: 13px;
      color: var(--amber);
      font-weight: 500;
      margin-top: 8px;
      position: relative;
      z-index: 1;
    }
    .s1-dot {
      width: 7px;
      height: 7px;
      background: var(--green);
      border-radius: 50%;
      animation: pulse 1.5s infinite;
    }
    @keyframes pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(0.85); }
    }

    /* ─────────────────────────────────────
       SCENE 2 — Vista general panel
    ───────────────────────────────────── */
    #scene2 { padding: 24px; gap: 0; align-items: flex-start; }
    .scene-float-text {
      position: absolute;
      bottom: 28px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(245,158,11,0.12);
      border: 1px solid rgba(245,158,11,0.3);
      backdrop-filter: blur(12px);
      padding: 10px 22px;
      border-radius: 100px;
      font-size: 14px;
      font-weight: 600;
      color: var(--amber);
      letter-spacing: 0.02em;
      white-space: nowrap;
      z-index: 10;
    }

    .panel-layout {
      width: 100%;
      height: 100%;
      display: grid;
      grid-template-columns: 1fr 320px 260px;
      gap: 12px;
    }
    .panel-card {
      background: var(--panel);
      border-radius: 14px;
      border: 1px solid var(--border);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .panel-header {
      padding: 14px 18px 10px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .panel-title {
      font-size: 13px;
      font-weight: 600;
      color: var(--text-secondary);
      text-transform: uppercase;
      letter-spacing: 0.08em;
    }
    .panel-body { flex: 1; overflow: hidden; padding: 12px; }

    /* Map */
    .map-container {
      width: 100%;
      height: 100%;
      background: #12151e;
      border-radius: 8px;
      position: relative;
      overflow: hidden;
    }
    .map-grid {
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
      background-size: 40px 40px;
    }
    .map-dot {
      position: absolute;
      border-radius: 50%;
      transform: translate(-50%, -50%);
    }

    /* Vendors list */
    .vendor-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 10px;
      background: rgba(255,255,255,0.03);
      border: 1px solid var(--border);
      margin-bottom: 8px;
      transition: background 0.2s;
    }
    .vendor-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .vendor-info { flex: 1; min-width: 0; }
    .vendor-name { font-size: 13px; font-weight: 600; color: var(--text); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .vendor-sub { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }
    .progress-wrap { margin-top: 5px; height: 3px; background: rgba(255,255,255,0.08); border-radius: 2px; overflow: hidden; }
    .progress-fill { height: 100%; border-radius: 2px; }
    .badge-suc { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 100px; white-space: nowrap; }

    /* Sidebar */
    .sidebar-stat {
      padding: 12px;
      background: rgba(255,255,255,0.03);
      border-radius: 10px;
      border: 1px solid var(--border);
      margin-bottom: 8px;
    }
    .stat-label { font-size: 11px; color: var(--text-secondary); margin-bottom: 4px; }
    .stat-value { font-size: 22px; font-weight: 700; }

    /* ─────────────────────────────────────
       SCENE 3 — Drill-down
    ───────────────────────────────────── */
    #scene3 { padding: 24px; align-items: flex-start; }
    .drilldown-layout {
      width: 100%;
      height: 100%;
      display: grid;
      grid-template-columns: 260px 1fr;
      gap: 12px;
    }
    .vendor-expanded {
      background: var(--panel);
      border-radius: 14px;
      border: 1px solid rgba(245,158,11,0.3);
      padding: 16px;
      box-shadow: 0 0 20px rgba(245,158,11,0.1);
    }
    .vendor-big-avatar {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 20px;
      font-weight: 700;
      margin-bottom: 10px;
    }
    .route-item {
      padding: 10px 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid var(--border);
      border-radius: 10px;
      margin-bottom: 7px;
      cursor: pointer;
      transition: background 0.2s;
    }
    .route-item.active-route {
      background: rgba(245,158,11,0.08);
      border-color: rgba(245,158,11,0.3);
    }
    .route-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .route-sub { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }
    .pdv-list { display: flex; flex-direction: column; gap: 8px; }
    .pdv-card {
      background: var(--panel);
      border-radius: 12px;
      border: 1px solid var(--border);
      padding: 14px 16px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      opacity: 0;
      transform: translateX(20px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .pdv-card.visible { opacity: 1; transform: translateX(0); }
    .pdv-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: rgba(245,158,11,0.1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      flex-shrink: 0;
    }
    .pdv-details { flex: 1; }
    .pdv-name { font-size: 14px; font-weight: 600; color: var(--text); }
    .pdv-addr { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
    .pdv-meta { display: flex; gap: 10px; margin-top: 8px; flex-wrap: wrap; }
    .meta-chip { font-size: 11px; padding: 3px 9px; border-radius: 6px; font-weight: 500; }
    .chip-green { background: rgba(34,197,94,0.15); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }
    .chip-muted { background: rgba(255,255,255,0.05); color: var(--text-secondary); border: 1px solid var(--border); }

    /* ─────────────────────────────────────
       SCENE 4 — Cuentas Corrientes
    ───────────────────────────────────── */
    #scene4 { padding: 24px; flex-direction: column; align-items: flex-start; justify-content: flex-start; gap: 12px; }
    .kpi-strip {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px;
    }
    .kpi-card {
      background: var(--panel);
      border-radius: 12px;
      border: 1px solid var(--border);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .kpi-label { font-size: 12px; color: var(--text-secondary); font-weight: 500; text-transform: uppercase; letter-spacing: 0.06em; }
    .kpi-value { font-size: 28px; font-weight: 800; letter-spacing: -1px; }
    .kpi-amber { color: var(--amber); }
    .kpi-red { color: var(--red); }
    .kpi-orange { color: var(--orange); }
    .cc-table-wrap {
      flex: 1;
      width: 100%;
      background: var(--panel);
      border-radius: 14px;
      border: 1px solid var(--border);
      overflow: hidden;
    }
    .cc-table-header {
      padding: 14px 18px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .cc-vendor-badge {
      display: flex;
      align-items: center;
      gap: 8px;
      background: rgba(245,158,11,0.1);
      border: 1px solid rgba(245,158,11,0.25);
      border-radius: 8px;
      padding: 4px 12px;
    }
    .cc-vendor-badge span { font-size: 13px; font-weight: 600; color: var(--amber); }
    table { width: 100%; border-collapse: collapse; }
    thead th {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      padding: 10px 16px;
      text-align: left;
      border-bottom: 1px solid var(--border);
    }
    tbody td {
      padding: 11px 16px;
      font-size: 13px;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: rgba(255,255,255,0.02); }
    .range-badge {
      display: inline-block;
      font-size: 11px;
      font-weight: 600;
      padding: 3px 8px;
      border-radius: 6px;
    }
    .range-green { background: rgba(34,197,94,0.15); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }
    .range-orange { background: rgba(249,115,22,0.15); color: var(--orange); border: 1px solid rgba(249,115,22,0.2); }
    .range-red { background: rgba(239,68,68,0.15); color: var(--red); border: 1px solid rgba(239,68,68,0.2); }
    .amount-text { font-weight: 700; color: var(--text); font-variant-numeric: tabular-nums; }

    /* ─────────────────────────────────────
       SCENE 5 — Vista Mobile
    ───────────────────────────────────── */
    #scene5 {
      background: radial-gradient(ellipse at center, #151820 0%, var(--bg) 100%);
    }
    .phone-frame {
      width: 360px;
      height: 680px;
      border-radius: 44px;
      border: 3px solid rgba(255,255,255,0.15);
      background: var(--bg);
      overflow: hidden;
      position: relative;
      box-shadow: 0 0 0 8px rgba(255,255,255,0.04), 0 30px 80px rgba(0,0,0,0.6), 0 0 40px rgba(245,158,11,0.1);
    }
    .phone-notch {
      height: 28px;
      background: var(--bg);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .phone-notch-pill {
      width: 80px;
      height: 6px;
      background: rgba(255,255,255,0.15);
      border-radius: 3px;
    }
    .phone-content {
      height: calc(100% - 28px);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .phone-topbar {
      padding: 8px 16px;
      background: var(--panel);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .phone-logo { font-size: 16px; font-weight: 900; letter-spacing: -1px; color: var(--amber); }
    .phone-body { flex: 1; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; gap: 8px; padding: 10px; }
    .phone-section { background: var(--panel); border-radius: 10px; border: 1px solid var(--border); padding: 10px; overflow: hidden; }
    .phone-section-title { font-size: 10px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
    .mobile-vendor {
      display: flex;
      align-items: center;
      gap: 7px;
      padding: 6px 0;
      border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .mobile-vendor:last-child { border-bottom: none; }
    .mobile-av { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; flex-shrink: 0; }
