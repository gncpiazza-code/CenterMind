            insertar_png_en_hoja(ws, info['path'], celda=info['cell'], width=600, height=420)
            
    wb.save(out_path)
    os.remove(temp_excel_path)
    
    # Limpiar PNGs
    for info in png_insertion_map.values():
        if os.path.exists(info['path']):
            os.remove(info['path'])
            
    return out_path, json_data
