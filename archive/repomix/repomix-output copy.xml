    .mobile-cc-amt { font-size: 11px; font-weight: 700; color: var(--red); }

    /* ─────────────────────────────────────
       SCENE 6 — Scanner GPS
    ───────────────────────────────────── */
    #scene6 {
      flex-direction: column;
      background: radial-gradient(ellipse at center bottom, #0d1a10 0%, var(--bg) 60%);
    }
    .radar-wrap {
      position: relative;
      width: 160px;
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 16px;
    }
    .radar-ring {
      position: absolute;
      border-radius: 50%;
      border: 1.5px solid rgba(34,197,94,0.5);
      animation: radarExpand 2.5s ease-out infinite;
    }
    .radar-ring:nth-child(2) { animation-delay: 0.8s; }
    .radar-ring:nth-child(3) { animation-delay: 1.6s; }
    @keyframes radarExpand {
      0%   { width: 50px; height: 50px; opacity: 0.9; }
      100% { width: 160px; height: 160px; opacity: 0; }
    }
    .radar-btn {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      background: rgba(34,197,94,0.15);
      border: 2px solid var(--green);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 26px;
      box-shadow: 0 0 20px rgba(34,197,94,0.3);
      animation: radarPulse 1.5s ease-in-out infinite alternate;
      position: relative;
      z-index: 2;
    }
    @keyframes radarPulse {
      from { box-shadow: 0 0 15px rgba(34,197,94,0.2); }
      to { box-shadow: 0 0 35px rgba(34,197,94,0.5); }
    }
    .gps-status {
      font-size: 13px;
      color: var(--green);
      font-weight: 500;
      margin-bottom: 24px;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .gps-dot { width: 6px; height: 6px; background: var(--green); border-radius: 50%; animation: pulse 1s infinite; }
    .nearby-list { display: flex; flex-direction: column; gap: 8px; width: 460px; }
    .nearby-item {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      opacity: 0;
      transform: translateY(12px);
      transition: opacity 0.4s ease, transform 0.4s ease;
    }
    .nearby-item.visible { opacity: 1; transform: translateY(0); }
    .nearby-dist {
      background: rgba(34,197,94,0.12);
      border: 1px solid rgba(34,197,94,0.2);
      color: var(--green);
      font-size: 11px;
      font-weight: 700;
      padding: 4px 10px;
      border-radius: 8px;
      white-space: nowrap;
    }
    .nearby-info { flex: 1; }
    .nearby-name { font-size: 13px; font-weight: 600; color: var(--text); }
    .nearby-sub { font-size: 11px; color: var(--text-secondary); margin-top: 2px; }

    /* ─────────────────────────────────────
       SCENE 7 — KPIs
    ───────────────────────────────────── */
    #scene7 {
      flex-direction: column;
      gap: 24px;
      background: radial-gradient(ellipse at center, #1a1408 0%, var(--bg) 70%);
    }
    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      width: 900px;
    }
    .kpi-big-card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 28px 24px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      box-shadow: 0 4px 24px rgba(0,0,0,0.3);
      transition: box-shadow 0.3s;
      position: relative;
      overflow: hidden;
    }
    .kpi-big-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 3px;
      border-radius: 16px 16px 0 0;
    }
    .kpi-big-card.amber::before { background: linear-gradient(90deg, var(--amber-dark), var(--amber)); }
    .kpi-big-card.green::before { background: linear-gradient(90deg, #15803d, var(--green)); }
    .kpi-big-card.red::before { background: linear-gradient(90deg, #991b1b, var(--red)); }
    .kpi-big-card.orange::before { background: linear-gradient(90deg, #9a3412, var(--orange)); }
    .kpi-big-icon { font-size: 28px; margin-bottom: 4px; }
    .kpi-big-value { font-size: 42px; font-weight: 800; letter-spacing: -2px; font-variant-numeric: tabular-nums; }
    .kpi-big-label { font-size: 13px; color: var(--text-secondary); font-weight: 500; }

    /* ─────────────────────────────────────
       SCENE 8 — Cierre
    ───────────────────────────────────── */
