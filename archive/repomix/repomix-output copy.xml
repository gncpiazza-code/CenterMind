│       ├── components/
│       │   ├── admin/          # TabSupervision.tsx + MapaRutas.tsx (mapa PDV con MapLibre)
│       │   ├── layout/         # Sidebar, Topbar, BottomNav
│       │   └── ui/             # shadcn/ui components
