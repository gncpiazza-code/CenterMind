        df = pd.read_excel(f, usecols=["dsempresa", "dssucur", "d_vendedor"])
        
        if df.empty:
            continue
            
        dsempresa = df.iloc[0]["dsempresa"]
        dist_id = dist_map.get(dsempresa)
        
