    border-radius: 12px;
    border: 1px solid var(--border);
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
  }
  /* Simulated map grid */
  .map-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
    background-size: 40px 40px;
  }
  .map-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 60%, rgba(6,182,212,0.04) 0%, transparent 50%),
                radial-gradient(ellipse at 70% 30%, rgba(34,197,94,0.04) 0%, transparent 40%);
  }
  /* Map road lines */
  .map-roads {
    position: absolute;
    inset: 0;
    opacity: 0.15;
  }
  .map-dot {
    position: absolute;
    border-radius: 50%;
    cursor: pointer;
    transform: translate(-50%, -50%) scale(0);
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
    z-index: 2;
  }
  .map-dot.visible { transform: translate(-50%, -50%) scale(1); }
  .map-dot.pulse::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2px solid currentColor;
    animation: dot-pulse 2s ease infinite;
  }
  @keyframes dot-pulse {
    0% { transform: scale(1); opacity: 0.6; }
    100% { transform: scale(2.5); opacity: 0; }
  }
  .map-label {
    position: absolute;
    background: rgba(15,17,23,0.9);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: 500;
    white-space: nowrap;
    pointer-events: none;
    transform: translate(-50%, calc(-100% - 10px));
    opacity: 0;
    transition: opacity 0.3s;
  }
  .map-dot:hover .map-label { opacity: 1; }

  /* Sellers panel */
  .sellers-panel {
    width: 280px;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    overflow-y: auto;
  }
  .seller-row {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    transition: all 0.3s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.3);
  }
  .seller-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    cursor: pointer;
  }
  .seller-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .seller-name {
    font-size: 13px;
    font-weight: 600;
    flex: 1;
  }
  .seller-count {
    font-size: 11px;
    color: var(--text3);
    font-weight: 500;
  }
  .seller-eye {
    width: 28px;
    height: 28px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    cursor: pointer;
    transition: all 0.2s;
    flex-shrink: 0;
  }
  .seller-eye.on {
    background: rgba(245,158,11,0.12);
    border-color: rgba(245,158,11,0.3);
  }
  .seller-routes {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease;
    border-top: 0px solid transparent;
  }
  .seller-routes.open {
    max-height: 300px;
    border-top: 1px solid var(--border);
  }
  .route-row {
    padding: 8px 14px 8px 34px;
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .route-row:last-child { border-bottom: none; }
  .route-icon { font-size: 12px; color: var(--text3); }
  .route-name { font-size: 12px; font-weight: 500; flex: 1; }
  .route-count { font-size: 10px; color: var(--text3); }
  .route-expand { font-size: 10px; color: var(--text3); transition: transform 0.3s; }
  .route-expand.open { transform: rotate(180deg); }
  .pdv-list {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
    background: rgba(0,0,0,0.2);
  }
  .pdv-list.open { max-height: 200px; }
  .pdv-row {
    padding: 8px 14px 8px 48px;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
  }
  .pdv-row:last-child { border-bottom: none; }
  .pdv-name { font-size: 11px; font-weight: 500; flex: 1; }
  .pdv-addr { font-size: 10px; color: var(--text3); }

  /* ===== SCENE 5: CUENTAS CORRIENTES ===== */
  .cc-kpi-strip {
    display: flex;
    gap: 14px;
    margin-bottom: 16px;
  }
  .cc-kpi {
    flex: 1;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 14px 18px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.3);
  }
  .cc-kpi-val {
    font-size: 22px;
    font-weight: 800;
    letter-spacing: -0.5px;
    color: var(--amber);
  }
  .cc-kpi-lbl { font-size: 11px; color: var(--text3); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.5px; }

  .cc-table-wrap {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
  }
  .cc-seller-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    cursor: pointer;
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid var(--border);
  }
  .cc-seller-name {
    font-size: 14px;
    font-weight: 700;
    flex: 1;
  }
  .cc-total {
    font-size: 14px;
    font-weight: 700;
    color: var(--amber);
  }
  .cc-chevron { font-size: 12px; color: var(--text3); transition: transform 0.3s; }
  .cc-chevron.open { transform: rotate(180deg); }
  .cc-rows { border-top: 1px solid var(--border); }
  .cc-table-head {
    display: grid;
    grid-template-columns: 2fr 1.2fr 0.7fr 1fr 1.2fr;
    padding: 8px 18px;
    font-size: 10px;
    font-weight: 600;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
  }
  .cc-row {
    display: grid;
    grid-template-columns: 2fr 1.2fr 0.7fr 1fr 1.2fr;
    padding: 12px 18px;
    align-items: center;
    border-bottom: 1px solid rgba(255,255,255,0.04);
    transition: background 0.2s;
    cursor: pointer;
  }
  .cc-row:last-child { border-bottom: none; }
  .cc-row:hover { background: rgba(255,255,255,0.02); }
  .cc-client { font-size: 13px; font-weight: 500; }
  .cc-days { font-size: 12px; color: var(--text3); }
  .cc-amount { font-size: 13px; font-weight: 600; text-align: right; }

  .csv-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: rgba(34,197,94,0.12);
    color: var(--green);
    border: 1px solid rgba(34,197,94,0.25);
    border-radius: 7px;
    padding: 7px 14px;
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .csv-btn:hover { background: rgba(34,197,94,0.2); }
