                        />
                      </div>
                      <div>
                        <label className="block text-xs text-[var(--shelfy-muted)] mb-1.5 font-medium">N° Cliente / Local</label>
                        <input
                          type="text" value={nroCliente} onChange={(e) => setNroCliente(e.target.value)}
