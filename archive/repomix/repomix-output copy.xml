    # Subtitle
    c.setFillColor(C_PRIMARY)
    c.setFont('Helvetica-Bold', 15)
    c.drawCentredString(w / 2, h * 0.53, 'Panel de Supervisión de Rutas de Venta')

    # Sub-subtitle
    c.setFillColor(colors.HexColor('#94a3b8'))
